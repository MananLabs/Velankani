# ═══════════════════════════════════════════════════════════
# VEL AI CLI — Environment Variables
# Copy to .env and fill in your actual API keys
# ═══════════════════════════════════════════════════════════

# OpenRouter API Configuration
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY_GPT=sk-or-xxxx
OPENROUTER_API_KEY_GEMINI=sk-or-xxxx
OPENROUTER_API_KEY_CLAUDE=sk-or-xxxx

# Optional: Use single API key for all models
# OPENROUTER_API_KEY=sk-or-xxxx

# CLI Settings
REQUEST_TIMEOUT_MS=30000
LOG_LEVEL=info

# Voice Input Settings
# Optional: Set to a partial name of your preferred microphone device.
# If not set, Bluetooth/headset devices are auto-preferred over built-in mics.
# Example: PREFERRED_MIC=headset   or   PREFERRED_MIC=bluetooth
# PREFERRED_MIC=

# Web Search Settings
# "Via Web Search" mode uses the existing AI model APIs (no external search API needed).
# Models are prompted in web-search assistant mode using the API keys already configured above.
